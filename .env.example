# ==============================================================================
# CONFIGURAÇÕES DE AMBIENTE VITALIA (Revisão Sistemática)
# ==============================================================================
# Este arquivo armazena credenciais e URIs sensíveis.
# NENHUMA regra de negócio ou configuração de threshold deve estar aqui.
# Para configurar timeouts, limites e regras, edite o 'criteria_config.yaml'.
# ==============================================================================

# URL base do servidor Ollama local (ex: http://localhost:11434 ou IP na rede)
OLLAMA_BASE_URL=http://localhost:11434

# Chave de API para o provedor em Nuvem (Gemini, OpenAI, etc.)
# Só será utilizada caso o LLMRouter faça o fallback ou seja configurado para 'cloud'
CLOUD_LLM_API_KEY=sua_chave_aqui
