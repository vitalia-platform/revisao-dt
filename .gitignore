
# Ignorar toda a estrutura gerada pelo Agente/Vitalia Kit
# Isso inclui os repositórios aninhados (session), storages e symlinks locais
.agent/
.agent/*
.specify/*
.specify
.DS_Store

# Variáveis de Ambiente e Segredos
.env
.env.*
!.env.example
# Ignorar contexto de sessão da IA (repósitorio aninhado isolado)
.agent/session/
.agent/session/*

# Ignorar storage de dados da revisão (repositório aninhado isolado)
.agent/data_storage/
.agent/data_storage/*

# Ignorar ambientes virtuais
.venv
venv

# Ignorar arquivos Python compilados e de cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Vitalia Spec Kit — contexto de sessão da IA (repo Git separado)
.specify/memory/session/
